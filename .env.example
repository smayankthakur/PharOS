# Required (all environments)
DATABASE_URL=postgresql://pharos:pharos@localhost:5432/pharos
JWT_SECRET=REPLACE_ME_WITH_64_CHAR_RANDOM
SYSTEM_OWNER_KEY=REPLACE_ME_WITH_64_CHAR_RANDOM
SYSTEM_ADMIN_EMAILS=owner@shakti.test
ALLOWED_ORIGINS=http://pharos.local:3000,http://*.pharos.local:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Optional but recommended
REDIS_URL=redis://localhost:6379
JWT_ISSUER=
JWT_AUDIENCE=
PORT=4000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_WINDOW_SEC=
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_MAX=120
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_SYSTEM_MAX=30
SEED_USER_PASSWORD=REPLACE_ME_DEV_ONLY_PASSWORD

# Tenant subdomain routing
BASE_DOMAIN=pharos.local
TENANT_HOST_SUFFIX=pharos.local
NEXT_PUBLIC_TENANT_HOST_SUFFIX=pharos.local
