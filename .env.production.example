DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require
REDIS_URL=rediss://default:<password>@<host>:6379
JWT_SECRET=replace_with_long_random_secret
SYSTEM_OWNER_KEY=replace_with_strong_system_owner_key
SYSTEM_ADMIN_EMAILS=owner@yourcompany.com,ops@yourcompany.com
PORT=4000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
ALLOWED_ORIGINS=https://pharos.app,https://*.pharos.app
API_URL=https://api.pharos.app
NEXT_PUBLIC_API_URL=https://api.pharos.app
